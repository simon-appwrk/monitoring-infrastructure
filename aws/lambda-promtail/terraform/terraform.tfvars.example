# Copy to terraform.tfvars (gitignored), fill in real values.

aws_access_key = "CHANGEME-AKIA..."
aws_secret_key = "CHANGEME-aws-secret"

region = "us-east-1"

# Public Loki push URL — cloudflared hostname pointing at NodePort 30100
loki_push_url = "https://loki-push.example.com/loki/api/v1/push"

# CloudWatch Log Groups to ship to Loki
log_group_names = [
  "/aws/lambda/payment-api",
  "/aws/rds/instance/payment-db/postgresql",
  "/ecs/auth-service",
]
