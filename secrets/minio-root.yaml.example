# MinIO root credentials. Referenced by helm-values/minio.yaml :: existingSecret.
# Copy to minio-root.yaml (gitignored), edit, then `kubectl apply -f minio-root.yaml`.

apiVersion: v1
kind: Secret
metadata:
  name: minio-root
  namespace: obs-storage
type: Opaque
stringData:
  rootUser: admin
  rootPassword: CHANGEME-strong-password-min-8-chars
