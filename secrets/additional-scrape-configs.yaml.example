# Prometheus's external scrape targets (VPS / EC2 / Docker hosts).
# This is a regular K8s Secret — using the secrets/ workflow keeps host IPs out of Git.
#
# Copy to additional-scrape-configs.yaml on the server (gitignored), edit the
# `prometheus-additional.yaml:` block, then `bash apply.sh` (or kubectl apply -f this).
#
# After updating, roll Prometheus to pick up changes:
#   kubectl -n obs-metrics rollout restart statefulset prometheus-kps-kube-prometheus-stack-prometheus

apiVersion: v1
kind: Secret
metadata:
  name: additional-scrape-configs
  namespace: obs-metrics
type: Opaque
stringData:
  prometheus-additional.yaml: |
    # ── VPS / EC2 hosts running node_exporter on :9100 ─────────────────
    - job_name: 'external-node-exporter'
      static_configs:
        - targets:
            - 'CHANGEME-vps-host-1:9100'
            - 'CHANGEME-vps-host-2:9100'
          labels:
            project: infra
            environment: production
            team: platform
            host_class: vps

    # ── Docker hosts running cAdvisor on :8080 ─────────────────────────
    # - job_name: 'external-cadvisor'
    #   static_configs:
    #     - targets: ['CHANGEME-docker-host:8080']
    #       labels:
    #         project: infra
    #         environment: production
    #         team: platform
    #         host_class: docker-host

    # ── App-specific /metrics endpoints ────────────────────────────────
    # - job_name: 'app-payment-api'
    #   metrics_path: /metrics
    #   static_configs:
    #     - targets: ['CHANGEME-app-host:8080']
    #       labels:
    #         project: payment-api
    #         environment: production
    #         team: backend
