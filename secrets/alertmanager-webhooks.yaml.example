# Webhook URLs for Alertmanager.
# Mounted by prometheus-operator at /etc/alertmanager/secrets/alertmanager-webhooks/<key>
# Referenced by helm-values/kube-prometheus-stack.yaml :: alertmanager.alertmanagerSpec.secrets.

apiVersion: v1
kind: Secret
metadata:
  name: alertmanager-webhooks
  namespace: obs-metrics
type: Opaque
stringData:
  # Slack incoming webhook URL (one for the platform team)
  slack-platform-url: https://hooks.slack.com/services/CHANGEME/CHANGEME/CHANGEME

  # SMTP password for global.smtp_auth_password_file
  smtp-password: CHANGEME-smtp-password

  # Add per-team webhooks as needed:
  # slack-url-payment-api: https://hooks.slack.com/services/CHANGEME/...
  # discord-url-payment-api: https://discord.com/api/webhooks/CHANGEME/...
  # telegram-bot-token: CHANGEME-bot-token
  # telegram-chat-id-payment-api: "CHANGEME-chat-id"
