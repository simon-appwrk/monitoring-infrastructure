# Loki's MinIO credentials. Loki reads these env vars natively via the AWS SDK.
# Referenced by helm-values/loki.yaml :: singleBinary.extraEnvFrom.
#
# AWS_ACCESS_KEY_ID  → also needs to be created as a MinIO user (see secrets/README.md)
# AWS_SECRET_ACCESS_KEY → must equal what you set when bootstrapping the MinIO user

apiVersion: v1
kind: Secret
metadata:
  name: loki-s3
  namespace: obs-logs
type: Opaque
stringData:
  AWS_ACCESS_KEY_ID: loki
  AWS_SECRET_ACCESS_KEY: CHANGEME-loki-minio-secret-key
