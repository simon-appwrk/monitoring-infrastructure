# Loki's MinIO credentials. Injected as env vars into the Loki Pod, then substituted
# into Loki's config via -config.expand-env=true (see helm-values/loki.yaml).
#
# MINIO_ACCESS_KEY → also needs to be created as a user inside MinIO (see secrets/README.md)
# MINIO_SECRET_KEY → must equal that user's password in MinIO

apiVersion: v1
kind: Secret
metadata:
  name: loki-s3
  namespace: obs-logs
type: Opaque
stringData:
  MINIO_ACCESS_KEY: loki
  MINIO_SECRET_KEY: CHANGEME-loki-minio-secret-key
