# Grafana ↔ Keycloak OIDC client secret.
#
# WHY THIS SECRET MUST EXIST EVEN IF YOU DON'T USE KEYCLOAK:
# helm-values/grafana.yaml has `envFromSecret: grafana-oidc`. If this Secret
# doesn't exist, Grafana's Pod fails to start (CreateContainerConfigError).
# So we apply it always — but the value is only consumed when OIDC is enabled.
#
# WHAT TO PUT HERE:
#   • Don't have Keycloak yet?    Leave the placeholder below as-is. Apply this Secret.
#                                 Grafana boots with the local admin login. Done for now.
#   • Have Keycloak set up?       Replace the placeholder with the real client secret:
#                                 Keycloak admin → Realm → Clients → grafana → Credentials tab
#                                 Then in helm-values/grafana.yaml flip
#                                 auth.generic_oauth.enabled to true and git push.

apiVersion: v1
kind: Secret
metadata:
  name: grafana-oidc
  namespace: obs-metrics
type: Opaque
stringData:
  # Safe placeholder — apply.sh accepts this. Replace ONLY when wiring Keycloak.
  GF_AUTH_GENERIC_OAUTH_CLIENT_SECRET: not-yet-configured
