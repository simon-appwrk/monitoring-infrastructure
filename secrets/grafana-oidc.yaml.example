# Grafana Keycloak client secret.
# Apply this even before you enable OIDC — the chart's envFromSecret references it.
# (With OIDC disabled, the env var is just dormant — harmless.)
#
# Required ONCE you flip auth.generic_oauth.enabled = true in helm-values/grafana.yaml.

apiVersion: v1
kind: Secret
metadata:
  name: grafana-oidc
  namespace: obs-metrics
type: Opaque
stringData:
  GF_AUTH_GENERIC_OAUTH_CLIENT_SECRET: CHANGEME-keycloak-client-secret-or-leave-as-placeholder-until-keycloak-ready
